# This repository is scoped to track ONLY the FTR10.Architect extension package.
# The git root (/home/ftr/.ftr10) is also the live ~/.ftr10 runtime profile, so
# ignore the entire tree and re-include just the package directory.
/*
!/FTR10.Architect/

# One-off pre-merge backup kept on disk for reference; never synced.
code-server-theme-sync-backup-*/

# Live profile artifacts at repo root (this dir IS ~/.ftr10). Tracked separately
# via the per-package .gitignore; the repo root only carries FTR10.Architect.
theme.json
shim.js
vars.json
terminal-colors.zsh
assets/
symbolic.links/
